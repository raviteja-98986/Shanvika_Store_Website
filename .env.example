# Firebase web config (Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=shanvika-rice-store.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=shanvika-rice-store
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you enabled Firebase Storage in Console (not required on free setup)
# VITE_FIREBASE_STORAGE_BUCKET=shanvika-rice-store.firebasestorage.app

# Free tier (recommended): leave false — images are compressed and stored in Firestore
# VITE_USE_FIREBASE_STORAGE=false
